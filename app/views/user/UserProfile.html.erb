<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home | Alpha Blog</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f0f2f5;
      font-family: 'Segoe UI', sans-serif;
    }
    .container {
      margin-top: 100px;
    }
    .card {
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
      border: none;
      transition: transform 0.2s ease;
    }
    .card:hover {
      transform: translateY(-5px);
    }
    .card-title {
      color: #007bff;
    }
    .action-buttons {
      margin-top: 10px;
    }
    .pagination-wrapper {
      display: flex;
      justify-content: center;
      margin-bottom: 30px;
    }
    .pagination {
      margin: 0;
    }
    .pagination .page-item .page-link {
      color: #007bff;
      border: 1px solid #dee2e6;
    }
    .pagination .page-item.active .page-link {
      background-color: #007bff;
      border-color: #007bff;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="container">
  <h2 class="mb-4">Welcome, <%= @user.name %> 👋</h2>

  <% if @user.profile_picture.attached? %>
    <%= image_tag @user.profile_picture, class: "img-thumbnail", width: 150 %>
  <% else %>
    <p>No profile picture uploaded.</p>

   <%= form_with url: upload_picture_path(@user), method: :post, local: true, html: { multipart: true } do |f| %>
  <div class="mb-3">
    <%= f.label :profile_picture, "Upload Profile Picture" %>
    <%= f.file_field :profile_picture, class: "form-control" %>
  </div>
  <%= f.submit "Upload", class: "btn btn-primary" %>
<% end %>

  <% end %>
</div>



    <% if @articles.any? %>
      <!-- Pagination Above Cards -->
      <div class="pagination-wrapper">
        <%= will_paginate @articles, renderer: WillPaginate::ActionView::LinkRenderer, class: "pagination" %>
      </div>

      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% @articles.each do |article| %>
          <div class="col">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title"><%= article.title %></h5>
                <p class="card-text"><%= truncate(article.description, length: 250) %></p>
              </div>
              <div class="card-footer bg-transparent border-top-0 d-flex justify-content-end gap-2 action-buttons">
                <%= link_to 'Edit', "/edit/#{article.id}", class: "btn btn-sm btn-outline-primary" %>
                <%= link_to 'Delete', "/delete/#{article.id}", method: :delete, data: { turbo: true }, class: "btn btn-sm btn-outline-danger" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info text-center mt-5">
        You haven't created any articles yet.
      </div>
    <% end %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
